generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Tabla `ias` — misma forma que supabase_tablas_minimo_es.sql
model AiTool {
  id           Int      @id @default(autoincrement()) /// nombre en BD: id
  name         String   @map("nombre")
  provider     String?  @map("proveedor")
  description  String   @map("descripcion")
  category     String   @map("categoria")
  urlApi       String?  @map("url_api")
  /// CHECK: free | basico | pro | empresarial
  requiredPlan String   @default("free") @map("plan_minimo")
  isActive     Boolean  @map("activa")
  createdAt    DateTime @default(now()) @map("fecha_creacion")
  updatedAt    DateTime @updatedAt @map("fecha_actualizacion")

  @@map("ias")
}

/// Tabla `usuarios` — misma forma que supabase_tablas_minimo_es.sql
model User {
  id                   Int      @id @default(autoincrement())
  name                 String   @map("nombre")
  email                String   @unique @map("correo")
  passwordHash         String   @map("hash_contrasena")
  /// CHECK: admin | usuario
  globalRole           String   @default("usuario") @map("rol_global")
  stripeCustomerId     String?  @map("id_cliente_stripe")
  stripeSubscriptionId String? @map("id_suscripcion_stripe")
  /// CHECK: activo | inactivo | moroso
  subscriptionStatus   String   @default("inactivo") @map("estado_suscripcion")
  /// CHECK: NULL o free | basico | pro | empresarial
  planType             String?  @map("tipo_plan")
  isActive             Boolean  @default(true) @map("activo")
  createdAt            DateTime @default(now()) @map("fecha_creacion")
  updatedAt            DateTime @updatedAt @map("fecha_actualizacion")

  @@map("usuarios")
}
