  "description": "Backend API for Astryx AI Suite built with Express, Prisma and Supabase PostgreSQL.",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/src/main.js",
