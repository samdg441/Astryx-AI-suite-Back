  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "bugs": {
    "url": "https://github.com/samdg441/Astryx-AI-suite-Back/issues"
  },
  "homepage": "https://github.com/samdg441/Astryx-AI-suite-Back#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "stripe": "^17.7.0",
