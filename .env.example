NODE_ENV="development"
PORT="4000"
API_PREFIX="/api/v1"
CORS_ORIGIN="http://localhost:3000"

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Frontend (URLs de retorno de Stripe Checkout)
FRONTEND_URL="http://localhost:3000"

# Stripe (modo test: https://dashboard.stripe.com/test/apikeys )
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs de productos en modo test (cada plan de la UI)
STRIPE_PRICE_BASICO=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_EMPRESARIAL=""

# Demo: permite POST /subscription/mock-activate (desactivar en producción)
MOCK_CHECKOUT_ENABLED="true"
